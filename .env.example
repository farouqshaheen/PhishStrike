# PhishStrike - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Flask Core ──────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_random_secret_string_here
DEBUG=False

# ─── Database ────────────────────────────────────────────────────────────────
# DB_PATH=auth/phishstrike.db

# ─── Dashboard Server ─────────────────────────────────────────────────────────
# Use 127.0.0.1 for local-only access (recommended)
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000
# socketio = live WebSocket updates | waitress = HTTP only (UI polls every 5s)
DASHBOARD_RUNTIME=socketio

# Optional: restrict SocketIO CORS (comma-separated)
# CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000

# CLI → dashboard capture notifications (auto-derived from SECRET_KEY if unset)
# INTERNAL_API_KEY=your_random_internal_key_here

# ─── Capture storage (optional) ──────────────────────────────────────────────
CAPTURE_ENCRYPT=false
RETENTION_DAYS=0
